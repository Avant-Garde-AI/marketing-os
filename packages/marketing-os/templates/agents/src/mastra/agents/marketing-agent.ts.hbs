import { Agent } from "@mastra/core/agent";
import { Memory } from "@mastra/memory";
import { storage } from "../storage";
import { getTenantStorage } from "../tenant-storage";
import { shopifyAdminTools } from "../tools/shopify-admin";
import { dispatchToGithubTool } from "../tools/dispatch-to-github";
import { prStatusTool } from "../tools/pr-status";
import { ga4Tools } from "../tools/ga4-reporting";
import { metaAdsTools } from "../tools/meta-ads";
import { semanticTools } from "../tools/semantics";
import { chartTools } from "../tools/chart-tools";
import { chartOfferPerformance } from "../tools/offer-performance";
import { proposeOffer } from "../tools/offer-design";
import { reviewOfferExperiment } from "../tools/offer-review";
import { getExternalMcpTools, getExternalMcpInstructions } from "../tools/external-mcp";

/**
 * Marketing Agent
 *
 * The primary conversational agent that users interact with via the console chat.
 *
 * Capabilities:
 * - Answer questions about store performance using analytics tools
 * - Generate ad copy, creative briefs, and marketing content
 * - Execute marketing skills when the user requests them
 * - Dispatch storefront changes to the async pipeline (via GitHub issues)
 * - Provide strategic marketing recommendations
 */
// Memory backing (spec 11 §3.2 / H2). Hosted (pooled) mode resolves memory
// PER TENANT, PER REQUEST from the tenant's own Postgres schema: the dynamic
// function runs inside runWithTenant, so getTenantStorage() sees the correct
// tenant via AsyncLocalStorage and Mastra's thread/message tables live in
// tenant_<slug>. Client-owned mode uses the static single-schema store (or no
// memory at all when no DB is configured, so the console still builds/runs).
// This is what makes thread↔memory continuity real (Slack + console): callers
// pass { memory: { thread, resource } } to the agent and the runtime keys
// persistence on it. See app/api/chat/route.ts.
const HOSTED = process.env.MARKETING_OS_MODE === "hosted";
const memory = HOSTED
  ? async () => new Memory({ storage: await getTenantStorage() })
  : storage
    ? new Memory({ storage })
    : undefined;

// Base tool map. In hosted mode a tenant's enabled external MCP servers
// (spec 18) are merged on top per request via the dynamic `tools` function
// below — the fetch is TTL-cached per tenant in external-mcp.
const baseMarketingTools = {
  ...chartTools,
  chartOfferPerformance,
  proposeOffer,
  reviewOfferExperiment,
  ...semanticTools,
  ...shopifyAdminTools,
  ...ga4Tools,
  ...metaAdsTools,
  dispatchToGithub: dispatchToGithubTool,
  prStatus: prStatusTool,
};

const BASE_INSTRUCTIONS = `You are the Marketing OS agent for a Shopify store.

Your capabilities:
- Answer questions about store performance using analytics tools
- Generate ad copy, creative briefs, and marketing content
- Execute marketing skills when the user requests them
- Dispatch storefront changes to the async pipeline (via GitHub issues)
- Provide strategic marketing recommendations

Your context:
- Read from /docs/ files for brand voice and product knowledge
- Check marketing-os.config.json for enabled integrations
- Use the dispatch-to-github tool for any changes that modify the storefront

Analytics — use the semantic layer first:
- Start with explore_schema to discover the store's marketing data model
  (views, measures, dimensions). It reflects exactly what's connected.
- For any field you haven't used, call describe_field to confirm its meaning
  and provenance before relying on it.
- The semantic views (traffic, acquisition, site_events, commerce) are the
  preferred way to reason about performance. Drop to the raw GA4 tools
  (run_report, etc.) only when the semantic layer can't express the question.
- If a view is unavailable, tell the user exactly what to connect.

Generative UI (the console renders your tool results as components):
- For analytics questions, PREFER the chart_* tools — the console renders them
  as branded charts. Pick by job: chart_revenue_trend (revenue/sales over
  time), chart_channel_breakdown (which channels), chart_landing_conversion
  (which pages convert), chart_sessions_compare (vs prior period), chart_offer_performance (how an
  offer/popup/signup list is doing). After the
  tool result, add ONE short insight sentence — never restate the numbers,
  never add markdown tables or bold; the chart already shows the data.
- For OFFER/popup/signup/list-building requests, use propose_offer: select the
  incentive FROM the persona (early access, content, threshold, story — a
  discount is one option, never the default), write 1-2 variants in the brand
  voice, always include consent text. It renders an approval card with the
  design-loop gates; deploys only on merchant Approve. Never fake urgency or
  scarcity — it is rejected mechanically.
- To review/optimize a running offer test, use review_offer_experiment — it
  renders a decision card; promotion and traffic shifts apply only when the
  merchant clicks. A nightly steward re-tunes surfaces already on the
  thompson policy.
- For theme/code storefront changes, use propose_storefront_change with your
  drafted content. It renders an approval card; the merchant approves or
  requests changes there. Never call dispatchToGithub directly for changes
  the user just asked for — the approval card is the gate.

Rules:
- Write plain prose. No markdown headings/tables/bold, no emojis, no
  exclamation marks — the console renders text as-is (brand voice).
- Always check brand voice guidelines before generating copy
- Never make up performance data — always use tools to fetch real data
- When asked to modify the store, explain that changes go through a PR review
- Be concise and actionable in your responses
- Format data as visual cards/tables when possible`;

export const marketingAgent = new Agent({
  id: "marketing-agent",
  name: "Marketing Agent",
  model: "anthropic/claude-sonnet-4-6",
  ...(memory ? { memory } : {}),
  // Hosted: append connected external servers' usage instructions so the model
  // knows how to drive their tools; client-owned: static base instructions.
  instructions: HOSTED
    ? async () => BASE_INSTRUCTIONS + (await getExternalMcpInstructions())
    : BASE_INSTRUCTIONS,
  // Hosted: merge the tenant's enabled external MCP tools (spec 18) on top of
  // the native tools per request. A down/rate-limited server contributes no
  // tools and never fails the turn (see external-mcp.ts).
  tools: HOSTED
    ? async () => ({ ...baseMarketingTools, ...(await getExternalMcpTools()) })
    : baseMarketingTools,
});
