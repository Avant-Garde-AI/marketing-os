{
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "app/api/skills/*/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/cron/research/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/offer-review",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/research",
      "schedule": "*/10 * * * *"
    }
  ]
}
