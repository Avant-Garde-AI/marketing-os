# Required (self-hosted: your own key; cloud: used for server-side agent calls)
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic Admin API (cloud only — provisions per-merchant workspaces)
# ANTHROPIC_ADMIN_KEY=sk-admin-...
# ANTHROPIC_ORG_ID=org-...

# Platform admin secret (cloud only — protects /admin dashboard)
# ADMIN_SECRET=your-random-secret-here

# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_DATABASE_URL=postgresql://postgres:...@db.your-project.supabase.co:5432/postgres

# Supabase (client-side - NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Shopify OAuth (Partner Dashboard app — recommended)
SHOPIFY_CLIENT_ID=your-client-id-from-partner-dashboard
SHOPIFY_CLIENT_SECRET=your-client-secret-from-partner-dashboard
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_customers,read_analytics,read_inventory,read_marketing_events
SHOPIFY_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_SHOPIFY_CLIENT_ID=your-client-id-from-partner-dashboard
# Set to "true" when running embedded inside Shopify Admin
SHOPIFY_EMBEDDED=false
NEXT_PUBLIC_SHOPIFY_EMBEDDED=false

# Shopify legacy fallback (self-hosted single-tenant only)
SHOPIFY_STORE_URL={{storeUrl}}
# SHOPIFY_ACCESS_TOKEN=shpat_... (deprecated — use OAuth instead)

# GitHub OAuth (for cloud onboarding — connects merchant's GitHub account)
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# GitHub (self-hosted fallback — for webhook validation and PR management)
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO={{repoFullName}}
GITHUB_WEBHOOK_SECRET=whsec_...

# Optional integrations (uncomment and configure as needed)
# GA4_PROPERTY_ID=123456789
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# META_ACCESS_TOKEN=EAAG...
# META_AD_ACCOUNT_ID=act_123456789
# GOOGLE_ADS_DEVELOPER_TOKEN=...
# GOOGLE_ADS_CUSTOMER_ID=123-456-7890
