import { Mastra } from "@mastra/core";
import { marketingAgent } from "./agents/marketing-agent";
import { creativeAgent } from "./agents/creative-agent";
import { brandDefinitionAgent } from "./agents/brand-definition-agent";
import { storage } from "./storage";

/**
 * Mastra instance for Marketing OS
 *
 * Configured with Marketing, Creative, and Brand Definition agents.
 * Storage is Supabase Postgres when SUPABASE_DATABASE_URL is set;
 * otherwise the console runs without persistence.
 */
export const mastra = new Mastra({
  agents: {
    marketingAgent,
    creativeAgent,
    brandDefinitionAgent,
  },
  ...(storage ? { storage } : {}),
});

export { marketingAgent, creativeAgent, brandDefinitionAgent };
