# ============================================================================
# Marketing OS — Self-Hosted Deployment (.env.production)
# ============================================================================
# Copy this to .env.production.local (gitignored) and fill in your values.
# In Vercel, set these as Environment Variables in your project settings.
#
# This is for SELF-HOSTED deployments — you create your own Partner App,
# Supabase project, and Anthropic account.
# ============================================================================

# ---------------------------------------------------------------------------
# App identity — your Vercel deployment URL
# ---------------------------------------------------------------------------
SHOPIFY_APP_URL=https://your-store-marketing-os.vercel.app
NEXT_PUBLIC_APP_URL=https://your-store-marketing-os.vercel.app

# ---------------------------------------------------------------------------
# Shopify Partner App (you create your own)
# Create at: partners.shopify.com → Apps → Create app
# ---------------------------------------------------------------------------
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_customers,read_analytics,read_inventory,read_marketing_events

# Set to "true" if you want the app embedded in Shopify Admin.
# Set to "false" for a standalone dashboard (no Shopify iframe).
SHOPIFY_EMBEDDED=true
NEXT_PUBLIC_SHOPIFY_CLIENT_ID=
NEXT_PUBLIC_SHOPIFY_EMBEDDED=true

# Shopify Partner Dashboard configuration:
#   App URL:                  https://your-store-marketing-os.vercel.app
#   Allowed redirection URL:  https://your-store-marketing-os.vercel.app/api/shopify/auth/callback

# ---------------------------------------------------------------------------
# GitHub OAuth App (you create your own)
# Create at: github.com/settings/developers → New OAuth App
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub OAuth App configuration:
#   Homepage URL:                https://your-store-marketing-os.vercel.app
#   Authorization callback URL:  https://your-store-marketing-os.vercel.app/api/github/auth/callback

# ---------------------------------------------------------------------------
# GitHub (optional — for webhook validation if not using GitHub OAuth)
# ---------------------------------------------------------------------------
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=your-org/your-store-theme
# GITHUB_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# Supabase (your own project)
# Create at: supabase.com → New project
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Anthropic (your own account + API key)
# Get from: console.anthropic.com
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Admin API — optional for self-hosted (only needed if managing multiple stores)
# ANTHROPIC_ADMIN_KEY=
# ANTHROPIC_ORG_ID=

# ---------------------------------------------------------------------------
# Platform admin — optional for self-hosted
# ---------------------------------------------------------------------------
# ADMIN_SECRET=

# ---------------------------------------------------------------------------
# Shopify legacy fallback (if not using OAuth)
# Only for local dev when you have a static custom app token.
# ---------------------------------------------------------------------------
# SHOPIFY_STORE_URL=mystore.myshopify.com
# SHOPIFY_ACCESS_TOKEN=shpat_...

# ---------------------------------------------------------------------------
# Optional integrations
# ---------------------------------------------------------------------------
# GA4_PROPERTY_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY=
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=
