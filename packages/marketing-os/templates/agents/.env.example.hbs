# Required
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_DATABASE_URL=postgresql://postgres:...@db.your-project.supabase.co:5432/postgres

# Supabase (client-side - NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Shopify
SHOPIFY_STORE_URL={{storeUrl}}
# Manual access token (legacy). Prefer the Marketing OS platform link below —
# install the Marketing OS app on your store and tokens are brokered automatically.
SHOPIFY_ACCESS_TOKEN=shpat_...

# Marketing OS platform (hosted). When set, the Shopify access token is fetched
# from the platform token broker instead of SHOPIFY_ACCESS_TOKEN.
# MARKETING_OS_API_URL=https://avant-garde-marketing-os.vercel.app
# MARKETING_OS_API_KEY=mos_...
# Deployment key for the credential broker (GA4 and other connected providers).
# Issued when you link this store to the Marketing OS platform.
# MARKETING_OS_DEPLOYMENT_KEY=mosdk_...

# Shopify OAuth (set these to use the automatic OAuth flow instead of manual tokens)
# SHOPIFY_APP_CLIENT_ID=your-app-client-id
# SHOPIFY_APP_CLIENT_SECRET=your-app-client-secret

# GitHub (for webhook validation and PR management)
GITHUB_TOKEN=ghp_...
GITHUB_REPO={{repoFullName}}
GITHUB_WEBHOOK_SECRET=whsec_...

# Design Studio (spec 23, optional). Managed Penpot backend for the agent's
# compose_design_surface / export_design_surface / list_design_surfaces tools.
# The tools degrade with a clear note when unset — nothing breaks without it.
# PENPOT_URL=https://design.example.com
# PENPOT_ACCESS_TOKEN=...
# Export lane (server-side renders) authenticates by SESSION, not access token:
# PENPOT_SERVICE_EMAIL=service@example.com
# PENPOT_SERVICE_PASSWORD=...
# Embedded Design Studio (/studio, spec 23 DS4). The store's SAME-SITE Penpot
# alias — it must share the console's registrable domain so cookies + the
# frame-ancestors patch admit the iframe (e.g. console www.example.cloud →
# design.example.cloud). Unset = /studio shows an editorial explainer instead.
# NEXT_PUBLIC_PENPOT_EMBED_URL=https://design.example.cloud
# Public base URL of this deployment, used to mint hosted render links
# (defaults to VERCEL_URL, then http://localhost:3000)
# MOS_AGENTS_PUBLIC_URL=https://agents.example.com

# Optional integrations (uncomment and configure as needed)
# GA4: connected via the Marketing OS Shopify app (Integrations → Connect Google).
# Tokens are brokered automatically; these are only for local dev without the broker.
# GA4_PROPERTY_ID=123456789
# GA4_ACCESS_TOKEN=ya29...
# META_ACCESS_TOKEN=EAAG...
# META_AD_ACCOUNT_ID=act_123456789
# GOOGLE_ADS_DEVELOPER_TOKEN=...
# GOOGLE_ADS_CUSTOMER_ID=123-456-7890
