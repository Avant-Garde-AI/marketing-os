# ============================================================================
# Marketing OS — Cloud Deployment (.env.production)
# ============================================================================
# Copy this to .env.production.local (gitignored) and fill in your values.
# In Vercel, set these as Environment Variables in the project settings.
#
# This is for the MANAGED CLOUD deployment at marketing-os.avant-garde.ai
# For self-hosted, see .env.self-hosted
# ============================================================================

# ---------------------------------------------------------------------------
# App identity
# ---------------------------------------------------------------------------
SHOPIFY_APP_URL=https://marketing-os.avant-garde.ai
NEXT_PUBLIC_APP_URL=https://marketing-os.avant-garde.ai

# ---------------------------------------------------------------------------
# Shopify Partner App (one app for all merchants)
# Get these from: partners.shopify.com → Apps → Your App → Client credentials
# ---------------------------------------------------------------------------
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_customers,read_analytics,read_inventory,read_marketing_events
SHOPIFY_EMBEDDED=true
NEXT_PUBLIC_SHOPIFY_CLIENT_ID=
NEXT_PUBLIC_SHOPIFY_EMBEDDED=true

# Shopify Partner Dashboard configuration:
#   App URL:                  https://marketing-os.avant-garde.ai
#   Allowed redirection URL:  https://marketing-os.avant-garde.ai/api/shopify/auth/callback

# ---------------------------------------------------------------------------
# GitHub OAuth App (connects merchant's GitHub account)
# Create at: github.com/organizations/Avant-Garde-AI/settings/applications/new
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub OAuth App configuration:
#   Homepage URL:                https://marketing-os.avant-garde.ai
#   Authorization callback URL:  https://marketing-os.avant-garde.ai/api/github/auth/callback

# ---------------------------------------------------------------------------
# Supabase (shared project — all merchants)
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Anthropic
# ---------------------------------------------------------------------------
# Server-side key for Mastra agent calls (your shared key)
ANTHROPIC_API_KEY=

# Admin API for per-merchant workspace provisioning
# Get from: console.anthropic.com → Settings → Admin API keys
ANTHROPIC_ADMIN_KEY=
ANTHROPIC_ORG_ID=

# ---------------------------------------------------------------------------
# Platform admin
# ---------------------------------------------------------------------------
# Protects /admin and /api/admin endpoints — generate a random string
ADMIN_SECRET=

# ---------------------------------------------------------------------------
# Optional integrations (uncomment and configure as needed)
# ---------------------------------------------------------------------------
# GA4_PROPERTY_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY=
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=
