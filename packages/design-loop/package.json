    "tsup": "^8.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Avant-Garde-AI/marketing-os",
    "directory": "packages/design-loop"
